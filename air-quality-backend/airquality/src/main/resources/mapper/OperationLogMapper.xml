<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.airquality.mapper.OperationLogMapper">

    <resultMap id="BaseResultMap" type="com.example.airquality.entity.OperationLog">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="username" property="username" />
        <result column="action" property="action" />
        <result column="target" property="target" />
        <result column="detail" property="detail" />
        <result column="ip" property="ip" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, username, action, target, detail, ip, created_at
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM operation_log WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM operation_log
        <where>
            <if test="action != null and action != ''">AND action = #{action}</if>
            <if test="username != null and username != ''">AND username LIKE CONCAT('%', #{username}, '%')</if>
        </where>
        ORDER BY created_at DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO operation_log (user_id, username, action, target, detail, ip, created_at)
        VALUES (#{userId}, #{username}, #{action}, #{target}, #{detail}, #{ip}, NOW())
    </insert>

    <delete id="deleteOlderThan">
        DELETE FROM operation_log WHERE created_at &lt; #{date}
    </delete>

    <select id="selectCount" resultType="long">
        SELECT COUNT(*) FROM operation_log
    </select>

</mapper>
